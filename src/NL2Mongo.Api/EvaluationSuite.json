  // ── nl2mongo: range queries (age) ─────────────────────────────────────────────
  // Note: allMustHave/noneCanHave only support equality checks; range assertions
  // use minCount only. The value of these cases is verifying the model generates
  // a valid, non-empty query using $gt/$lt/$gte/$lte.
  {
    "id": "nl2mongo-age-over-50",
    "description": "contacts over 50",
    "tenant": "nl2mongo",
    "minCount": 1
  },
